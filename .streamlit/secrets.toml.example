# Copy this file to .streamlit/secrets.toml and fill in your API keys
# DO NOT commit secrets.toml to git (it's in .gitignore)

OPENAI_API_KEY = "sk-your-key-here"
PERPLEXITY_API_KEY = "your-perplexity-key"
ELEVENLABS_API_KEY = "your-elevenlabs-key"
TELEGRAM_BOT_TOKEN = "your-telegram-bot-token"
TELEGRAM_CHAT_ID = "your-chat-id"
NICHE = "AI Technology"
TARGET_AUDIENCE = "Tech enthusiasts and professionals"
BRAND_VOICE = "Informative and engaging"
BRAND_COLORS = '["#FF6B6B", "#4ECDC4", "#45B7D1"]'
